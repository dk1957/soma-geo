# Dependencies are reinstalled inside the image via `pnpm install`.
node_modules
**/node_modules

# Old / reference apps that are NOT part of the deployable build. Keeping them
# out of the build context avoids copying dead code and prevents their type
# errors or tooling from interfering with the image build.
soma_v2
web
badseo

# Local build output and caches — regenerated by `vite build` in the container.
dist
dist-sourcemaps
.wrangler
.alchemy
.logs
**/*.log

# Secrets and local env files must never be baked into the image. Runtime env
# is provided by Docker Compose / the platform instead.
.env
.env.*
!.env.example

# VCS and editor metadata.
.git
.gitignore
.vscode
.idea

# Tests and CI artifacts that aren't needed to build or run the server.
e2e
playwright-report
test-results
coverage

# Docs and misc developer files.
docs
runbooks
release-notes
specs
